# Environment Variables for PacketScope

# Port for the server (Render sets this automatically)
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/packetscope

# Frontend URL for CORS (add your Render frontend URL)
FRONTEND_URL=https://your-frontend-app.onrender.com

# Python path (optional, defaults to python/python3)
PYTHON_PATH=python3